{
  "name": "limn",
  "version": "0.3.0",
  "private": true,
  "description": "Agentic local branch review — guided code review backed by Claude or Codex",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glebmish/limn.git"
